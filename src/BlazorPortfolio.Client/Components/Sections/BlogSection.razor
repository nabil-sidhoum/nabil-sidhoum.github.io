<section id="blog" data-screen-label="05 Blog">
    <h2 class="h-readme">blog <span class="sub">@(_articles.Count > 0 ? "— derniers articles" : "— articles à venir")</span></h2>

    @if (_articles.Count == 0)
    {
        <p class="comment section-comment">Drafts en cours. La grille est prête, les articles arriveront ici.</p>

        <div class="blog-grid">
            <div class="blog-ghost">
                <span class="todo">// TODO[1]</span>
                <p class="ghost-title">Article à venir</p>
                <span class="ghost-date">0000-00-00</span>
            </div>
            <div class="blog-ghost">
                <span class="todo">// TODO[2]</span>
                <p class="ghost-title">Article à venir</p>
                <span class="ghost-date">0000-00-00</span>
            </div>
            <div class="blog-ghost">
                <span class="todo">// TODO[3]</span>
                <p class="ghost-title">Article à venir</p>
                <span class="ghost-date">0000-00-00</span>
            </div>
        </div>
    }
    else
    {
        <div class="blog-grid">
            @foreach (BlogArticle article in _articles)
            {
                <a href="/blog/@article.Slug" class="blog-card">
                    <span class="blog-card-date">@article.PublishedAt</span>
                    <p class="blog-card-title">@article.Title</p>
                    <div class="tags">
                        @foreach (string tag in article.Tags)
                        {
                            <span class="pill">@tag</span>
                        }
                    </div>
                </a>
            }
        </div>

        <a href="/blog" class="blog-all-link">// voir tous les articles →</a>
    }
</section>
