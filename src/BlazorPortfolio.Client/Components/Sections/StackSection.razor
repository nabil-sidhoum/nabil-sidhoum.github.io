<section class="stack" id="stack" data-screen-label="02 Stack">
    <h2 class="h-readme">stack <span class="sub">— deux domaines distincts</span></h2>
    <p class="comment section-comment">Listés séparément par choix : la stack .NET est la base ; l'IA est l'extension récente.</p>

    <div class="skills-block">
        @foreach (StackCategoryInfo category in _categories)
        {
            <div class="skill-row">
                <div class="key">@category.Key</div>
                <div class="pills">
                    @foreach (string item in category.Items)
                    {
                        <span class="@(category.IsAccent ? "pill accent" : "pill")">@item</span>
                    }
                </div>
            </div>
        }
    </div>
</section>
